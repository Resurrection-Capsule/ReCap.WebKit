# Normalize line endings: LF in the repo, native on checkout for shell scripts.
* text=auto eol=lf

*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf
*.sln   text eol=crlf
*.vcxproj text eol=crlf

# Binary assets — never normalize.
*.png   binary
*.ico   binary
*.dll   binary
*.lib   binary
*.exp   binary
*.pdb   binary
